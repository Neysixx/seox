{
	"name": "seox-monorepo",
	"private": true,
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"prepare": "husky",
		"format:check": "biome check",
		"format:fix": "biome check --write",
		"build": "bun run --cwd packages/seox build",
		"build:all": "bun run --filter '*' build",
		"dev:landing": "bun run --cwd apps/landing dev",
		"dev:docs": "bun run --cwd apps/docs dev",
		"test": "bun run --cwd packages/seox test",
		"typecheck": "bun run --cwd packages/seox typecheck",
		"ci": "bun run typecheck && bun run format:check && bun run test && bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.4",
		"husky": "^9.1.7",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=18.0.0",
		"bun": ">=1.0.0"
	}
}
