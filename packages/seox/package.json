{
	"name": "seox",
	"version": "1.3.0",
	"publishConfig": {
		"access": "public"
	},
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"bin": {
		"seox": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./next": {
			"types": "./dist/next.d.ts",
			"import": "./dist/next.js",
			"require": "./dist/next.cjs"
		}
	},
	"type": "module",
	"author": "Kyllian SENRENS <kylliansenrens3004@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/neysixx/seox.git",
		"directory": "packages/seox"
	},
	"scripts": {
		"build": "NODE_ENV=production tsup",
		"build:dev": "NODE_ENV=development tsup",
		"build:watch": "NODE_ENV=development tsup --watch",
		"build:analyze": "ANALYZE=true NODE_ENV=production tsup",
		"dev": "NODE_ENV=development tsup --watch",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"nextjs",
		"seo",
		"typescript"
	],
	"devDependencies": {
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/bun": "latest",
		"@types/fs-extra": "^11.0.4",
		"@types/prompts": "^2.4.9",
		"@types/react": "^19.1.8",
		"happy-dom": "^20.3.7",
		"next": "^15.3.4",
		"react": "^19.1.0",
		"tsup": "^8.5.0"
	},
	"dependencies": {
		"chalk": "^5.3.0",
		"commander": "^11.1.0",
		"fs-extra": "^11.2.0",
		"jiti": "^2.6.1",
		"ora": "^7.0.1",
		"prompts": "^2.4.2"
	},
	"peerDependencies": {
		"typescript": "^5.9.3",
		"next": ">=14.0.0",
		"react": ">=18.0.0"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": false
		},
		"react": {
			"optional": false
		}
	},
	"engines": {
		"node": ">=18.0.0",
		"bun": ">=1.0.0"
	}
}
